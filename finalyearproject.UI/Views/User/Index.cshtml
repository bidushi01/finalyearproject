@{
    ViewData["Title"] = "User Dashboard";
    Layout = "_Layout";
}

<style>
    .user-dashboard-wrapper {
        padding: 30px;
        max-width: 1100px;
        margin: 0 auto;
    }

    .user-grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
        margin-top: 24px;
    }

    .user-card {
        background: #16213e;
        border-radius: 14px;
        padding: 18px 20px;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .user-card-title {
        font-size: 0.9rem;
        color: #6b8fa8;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }

    .user-card-body {
        color: #e8f4f8;
        font-size: 0.95rem;
    }
</style>

<div class="user-dashboard-wrapper">
    <h2 class="fw-bold" style="color:#e8f4f8;">Hi, @User.Identity?.Name 👋</h2>
    <p class="text-muted mb-4">This is your main workspace. From here you can manage your skills and ask for help.</p>

    <div class="user-grid-2">
        <div class="user-card">
            <div class="user-card-title">Profile & Skills</div>
            <div class="user-card-body">
                <p class="mb-2">Update your skills, sub-skills, experience level and availability.</p>
                <p class="mb-2">Changes will be sent to the admin for approval before they go live.</p>
                <a asp-controller="User" asp-action="Profile" class="btn btn-sm btn-outline-light mt-2">Open profile</a>
            </div>
        </div>

        <div class="user-card">
            <div class="user-card-title">Ask for help</div>
            <div class="user-card-body">
                <p class="mb-2">Create a help request by choosing field, skill, sub-skill, time slot and describing your problem.</p>
                <p class="mb-2">For now requests will be stored and visible to admin; matching algorithm comes later.</p>
                <a asp-controller="User" asp-action="AskHelp" class="btn btn-sm btn-outline-light mt-2">Ask for help</a>
            </div>
        </div>
    </div>
</div>
