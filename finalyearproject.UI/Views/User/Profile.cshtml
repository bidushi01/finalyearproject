@{
    ViewData["Title"] = "My Profile";
    Layout = "_Layout";
}

<style>
    .profile-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    /* ── Header Card ── */
    .profile-hero {
        background: linear-gradient(135deg, #16213e 60%, #1a1040 100%);
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: 18px;
        padding: 28px 32px;
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
    }

        .profile-hero::before {
            content: '';
            position: absolute;
            top: -40px;
            right: -40px;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(124,58,237,0.18) 0%, transparent 70%);
            border-radius: 50%;
        }

    .avatar-circle {
        width: 72px;
        height: 72px;
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
        box-shadow: 0 0 0 4px rgba(124,58,237,0.25);
    }

    .profile-meta h2 {
        color: #e8f4f8;
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0 0 4px;
    }

    .profile-meta .badge-approved {
        background: rgba(72,187,120,0.15);
        color: #48bb78;
        border: 1px solid #48bb78;
        border-radius: 20px;
        padding: 2px 12px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .profile-info-row {
        display: flex;
        gap: 20px;
        margin-top: 8px;
        flex-wrap: wrap;
    }

    .profile-info-item {
        color: #6b8fa8;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .profile-info-item span {
            color: #c8dde8;
        }

    /* ── Stat Pills ── */
    .stat-pills {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 28px;
    }

    .stat-pill {
        background: #16213e;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 14px 22px;
        flex: 1;
        min-width: 140px;
        text-align: center;
    }

        .stat-pill .num {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(90deg, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-pill .label {
            color: #6b8fa8;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 2px;
        }

    /* ── Skills Section ── */
    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
    }

    .section-title {
        color: #e8f4f8;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-title::before {
            content: '';
            width: 4px;
            height: 20px;
            background: #7c3aed;
            border-radius: 2px;
        }

    /* ── Skill Cards ── */
    .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 14px;
    }

    .skill-card {
        background: #16213e;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 14px;
        padding: 16px 18px;
        transition: border-color 0.2s, transform 0.2s;
    }

        .skill-card:hover {
            border-color: rgba(124,58,237,0.4);
            transform: translateY(-2px);
        }

    .skill-field {
        font-size: 0.7rem;
        color: #7c3aed;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .skill-name {
        color: #e8f4f8;
        font-size: 1rem;
        font-weight: 700;
    }

    .skill-sub {
        color: #6b8fa8;
        font-size: 0.82rem;
        margin-top: 2px;
    }

    .skill-footer {
        display: flex;
        gap: 8px;
        margin-top: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    .badge-level {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .level-1 {
        background: rgba(107,140,168,0.15);
        color: #6b8fa8;
        border: 1px solid #6b8fa8;
    }

    .level-2 {
        background: rgba(96,165,250,0.15);
        color: #60a5fa;
        border: 1px solid #60a5fa;
    }

    .level-3 {
        background: rgba(167,139,250,0.15);
        color: #a78bfa;
        border: 1px solid #a78bfa;
    }

    .level-4 {
        background: rgba(52,211,153,0.15);
        color: #34d399;
        border: 1px solid #34d399;
    }

    .skill-avail {
        color: #6b8fa8;
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* ── Empty State ── */
    .empty-skills {
        background: #16213e;
        border: 2px dashed rgba(124,58,237,0.25);
        border-radius: 14px;
        padding: 48px 20px;
        text-align: center;
        color: #6b8fa8;
    }

        .empty-skills .icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-skills p {
            margin: 0 0 16px;
        }

    /* ── Quick Actions ── */
    .quick-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 28px;
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.88rem;
        text-decoration: none;
        transition: opacity 0.2s, transform 0.15s;
        border: none;
        cursor: pointer;
    }

        .action-btn:hover {
            opacity: 0.85;
            transform: translateY(-1px);
        }

    .action-btn-primary {
        background: #7c3aed;
        color: white;
    }

    .action-btn-outline {
        background: transparent;
        color: #a78bfa;
        border: 1px solid rgba(124,58,237,0.4);
    }

    .action-btn-success {
        background: rgba(72,187,120,0.15);
        color: #48bb78;
        border: 1px solid #48bb78;
    }
</style>

<div class="profile-wrapper">

    <!-- ── Hero / User Info ── -->
    <div class="profile-hero">
        <div class="avatar-circle" id="avatarCircle">
            @User.Identity?.Name?.Substring(0, 1).ToUpper()
        </div>
        <div class="profile-meta">
            <h2>@User.Identity?.Name</h2>
            <span class="badge-approved">✓ Verified Member</span>
            <div class="profile-info-row" id="profileInfoRow">
                <div class="profile-info-item"> <span id="userEmail">Loading...</span></div>
                <div class="profile-info-item"> <span id="userPhone">Loading...</span></div>
                <div class="profile-info-item"> <span id="userJoined">Loading...</span></div>
            </div>
        </div>
    </div>

    <!-- ── Stats ── -->
    <div class="stat-pills">
        <div class="stat-pill">
            <div class="num" id="statSkills">—</div>
            <div class="label">Skills Listed</div>
        </div>
        <div class="stat-pill">
            <div class="num" id="statSessions">0</div>
            <div class="label">Sessions Completed</div>
        </div>
        <div class="stat-pill">
            <div class="num" id="statPoints">0</div>
            <div class="label">Points Earned</div>
        </div>
    </div>

    <!-- ── Quick Actions ── -->
    <div class="quick-actions">
        <a asp-controller="Account" asp-action="AddSkills" class="action-btn action-btn-primary">
            Add New Skill
        </a>
        <button type="button" class="action-btn action-btn-outline" id="btnEditCv">
            Edit CV &amp; Portfolio
        </button>
        <a asp-controller="User" asp-action="AskHelp" class="action-btn action-btn-success">
            Ask for Help
        </a>
        <a asp-controller="Account" asp-action="ChangePassword" class="action-btn action-btn-outline">
            Change Password
        </a>
    </div>

    <!-- ── Skills Section ── -->
    <div class="section-header">
        <div class="section-title">My Skills Portfolio</div>
        <a asp-controller="Account" asp-action="AddSkills"
           style="color:#a78bfa;font-size:0.85rem;text-decoration:none;">
            Manage All →
        </a>
    </div>

    <div class="skills-grid" id="skillsContainer">
        <!-- Populated by JS -->
        <div class="empty-skills" id="loadingSkills">
            <div class="icon">⏳</div>
            <p>Loading your skills...</p>
        </div>
    </div>

    <!-- CV / Portfolio edit modal -->
    <div class="modal fade" id="editCvModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-md modal-dialog-centered">
            <div class="modal-content" style="background:#161b2c;border:1px solid rgba(255,255,255,0.1);">
                <div class="modal-header">
                    <h5 class="modal-title">Edit CV &amp; Portfolio</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Upload CV</label>
                        <input type="file" id="editCvFile" class="form-control" accept=".pdf,.doc,.docx" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Portfolio URL</label>
                        <input type="text" id="editPortfolioUrl" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="btnSaveCvEdit">Save</button>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/userProfile.js"></script>
}
