@{
    ViewData["Title"] = "Ask for Help";
    Layout = "_Layout";
}

<style>
    .askhelp-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    /* ── Page Header ── */
    .page-header {
        margin-bottom: 28px;
    }

        .page-header h2 {
            color: #e8f4f8;
            font-size: 1.7rem;
            font-weight: 700;
            margin: 0 0 6px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-header p {
            color: #6b8fa8;
            margin: 0;
            font-size: 0.9rem;
        }

    /* ── Step Card ── */
    .step-card {
        background: #16213e;
        border: 1px solid rgba(124,58,237,0.25);
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 20px;
    }

    .step-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #7c3aed;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .step-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(124,58,237,0.2);
        }

    .step-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        align-items: end;
    }

    .form-group label {
        display: block;
        color: #6b8fa8;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    .dx-selectbox-container, .dx-widget {
        border-radius: 8px !important;
    }

    /* ── Search Button ── */
    .search-btn-wrap {
        display: flex;
        align-items: flex-end;
    }

    /* ── Status Banner ── */
    .status-banner {
        background: rgba(124,58,237,0.1);
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: 10px;
        padding: 12px 18px;
        color: #a78bfa;
        font-size: 0.85rem;
        margin-bottom: 20px;
        display: none;
        align-items: center;
        gap: 10px;
    }

    /* ── Results Section ── */
    .results-section {
        display: none;
    }

    .results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .results-title {
        color: #e8f4f8;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .results-count {
        background: rgba(124,58,237,0.15);
        color: #a78bfa;
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 0.8rem;
    }

    /* ── Helper Cards ── */
    .helpers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 16px;
    }

    .helper-card {
        background: #16213e;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 20px;
        transition: border-color 0.2s, transform 0.2s;
        position: relative;
        overflow: hidden;
    }

        .helper-card.top-pick {
            border-color: rgba(124,58,237,0.5);
            box-shadow: 0 0 0 1px rgba(124,58,237,0.2);
        }

            .helper-card.top-pick::before {
                content: '⭐ Best Match';
                position: absolute;
                top: 0;
                right: 0;
                background: #7c3aed;
                color: white;
                font-size: 0.65rem;
                font-weight: 700;
                padding: 4px 12px;
                border-bottom-left-radius: 10px;
            }

        .helper-card:hover {
            border-color: rgba(124,58,237,0.4);
            transform: translateY(-2px);
        }

    .helper-rank {
        font-size: 0.7rem;
        color: #6b8fa8;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    .helper-name {
        color: #e8f4f8;
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 2px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .helper-avatar {
        width: 28px;
        height: 28px;
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        color: white;
    }

    .helper-skill-info {
        color: #6b8fa8;
        font-size: 0.82rem;
        margin: 8px 0 12px;
    }

    .badge-level {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
        display: inline-block;
    }

    .level-1 {
        background: rgba(107,140,168,0.15);
        color: #6b8fa8;
        border: 1px solid #6b8fa8;
    }

    .level-2 {
        background: rgba(96,165,250,0.15);
        color: #60a5fa;
        border: 1px solid #60a5fa;
    }

    .level-3 {
        background: rgba(167,139,250,0.15);
        color: #a78bfa;
        border: 1px solid #a78bfa;
    }

    .level-4 {
        background: rgba(52,211,153,0.15);
        color: #34d399;
        border: 1px solid #34d399;
    }

    .request-btn {
        width: 100%;
        background: #7c3aed;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, opacity 0.2s;
        margin-top: 12px;
    }

        .request-btn:hover {
            background: #6d28d9;
        }

        .request-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* ── Empty/Loading States ── */
    .no-helpers {
        background: #16213e;
        border: 2px dashed rgba(255,255,255,0.1);
        border-radius: 14px;
        padding: 48px 20px;
        text-align: center;
        color: #6b8fa8;
        grid-column: 1 / -1;
    }

        .no-helpers .icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

    /* ── Request Sent Modal ── */
    .request-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(4px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .request-overlay.show {
            display: flex;
        }

    .request-modal {
        background: #16213e;
        border: 1px solid rgba(124,58,237,0.4);
        border-radius: 18px;
        padding: 36px 40px;
        text-align: center;
        max-width: 400px;
        animation: popIn 0.25s ease;
    }

    @@keyframes popIn {
        from {
            transform: scale(0.85);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .request-modal .big-icon {
        font-size: 3.5rem;
        margin-bottom: 12px;
    }

    .request-modal h4 {
        color: #e8f4f8;
        margin: 0 0 8px;
    }

    .request-modal p {
        color: #6b8fa8;
        font-size: 0.88rem;
        margin: 0 0 20px;
    }

    .modal-close-btn {
        background: #7c3aed;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 28px;
        font-weight: 600;
        cursor: pointer;
    }
</style>

<div class="askhelp-wrapper">

    <!-- ── Header ── -->
    <div class="page-header">
        <h2>🙋 Ask for Help</h2>
        <p>Find a verified expert who can help you. Select a skill and we'll match you with the best helpers.</p>
    </div>

    <!-- ── Selection Step ── -->
    <div class="step-card">
        <div class="step-label">Step 1 — Choose the Skill You Need Help With</div>
        <div class="step-grid">
            <div class="form-group">
                <label>Field</label>
                <div id="selectField"></div>
            </div>
            <div class="form-group">
                <label>Skill</label>
                <div id="selectSkill"></div>
            </div>
            <div class="form-group">
                <label>Sub-Skill</label>
                <div id="selectSubSkill"></div>
            </div>
            <div class="form-group">
                <label>Available Day</label>
                <div id="selectDay"></div>
            </div>
            <div class="form-group">
                <label>Preferred Time (From)</label>
                <div id="preferredStart"></div>
            </div>
            <div class="form-group">
                <label>Preferred Time (To)</label>
                <div id="preferredEnd"></div>
            </div>
            <div class="form-group search-btn-wrap">
                <div id="btnSearch" style="width:100%;"></div>
            </div>
        </div>
        <div class="form-group mt-3">
            <label>Problem Description</label>
            <textarea id="txtProblemDesc" class="form-control" rows="3" placeholder="Describe what you need help with..." style="background:#0a0f1d;border:1px solid rgba(255,255,255,0.2);color:#fff;border-radius:8px;"></textarea>
        </div>
    </div>

    <!-- ── Status Banner ── -->
    <div class="status-banner" id="statusBanner">
        <span id="statusIcon">🔍</span>
        <span id="statusText">Searching for helpers...</span>
    </div>

    <!-- ── Results ── -->
    <div class="results-section" id="resultsSection">
        <div class="results-header">
            <div class="results-title">
                Matching Helpers
                <span class="results-count" id="helperCount">0 found</span>
            </div>
            <span style="color:#6b8fa8;font-size:0.8rem;">Sorted by experience level</span>
        </div>
        <div class="helpers-grid" id="helpersGrid"></div>
    </div>

</div>

<!-- ── Request Sent Overlay ── -->
<div class="request-overlay" id="requestOverlay">
    <div class="request-modal">
        <div class="big-icon">✅</div>
        <h4>Request Sent!</h4>
        <p>
            Your request has been sent to <strong id="requestedHelperName">the helper</strong>.<br>
            They will see it under <strong>My Requests</strong> with Accept / Reject. After they accept, you can chat there.
        </p>
        <p class="small text-muted mb-2">If no response in 2 minutes, we'll suggest the next best helper.</p>
        <div id="nextHelperArea" style="display:none; margin-bottom:12px;">
            <p class="small mb-1">Helper didn't respond. Send to next: <strong id="nextHelperName"></strong>?</p>
            <button type="button" class="btn btn-sm btn-primary" id="sendToNextBtn">Send to this helper</button>
        </div>
        <a href="/User/MyHelpRequests" class="modal-close-btn mb-2 d-inline-block text-decoration-none text-center">📬 View My Requests</a>
        <button class="modal-close-btn" onclick="document.getElementById('requestOverlay').classList.remove('show'); clearTimeout(window._requestTimeout);">
            Got it
        </button>
    </div>
</div>

@section Scripts {
    <script>
        const levelMap   = { 1: 'Student / Final Year / Intern', 2: '0-3 Yrs', 3: '3-5 Yrs', 4: '5+ Yrs' };
        const levelClass = { 1: 'level-1', 2: 'level-2', 3: 'level-3', 4: 'level-4' };

        let selectedSubSkillId = null;
        let lastSearch = { fieldId: null, skillId: null, subSkillId: null, timeStart: '', timeEnd: '', day: '' };

        // ── Field Dropdown (same data as Register; no "Add New" option for Ask Help) ──
        $('#selectField').dxSelectBox({
            dataSource: '/Account/GetFields',
            displayExpr: 'FieldName',
            valueExpr: 'FieldId',
            placeholder: 'Choose field...',
            stylingMode: 'outlined',
            onValueChanged: function (e) {
                const skillBox = $('#selectSkill').dxSelectBox('instance');
                skillBox.option('dataSource', e.value ? '/Account/GetSkillsByField?fieldId=' + e.value : []);
                skillBox.option('value', null);
                const subBox = $('#selectSubSkill').dxSelectBox('instance');
                subBox.option('dataSource', []);
                subBox.option('value', null);
                selectedSubSkillId = null;
            }
        });

        // ── Skill Dropdown ──
        $('#selectSkill').dxSelectBox({
            displayExpr: 'SkillName',
            valueExpr: 'SkillId',
            placeholder: 'Choose skill...',
            stylingMode: 'outlined',
            onValueChanged: function (e) {
                const subBox = $('#selectSubSkill').dxSelectBox('instance');
                subBox.option('dataSource', e.value ? '/Account/GetSubSkillsBySkill?skillId=' + e.value : []);
                subBox.option('value', null);
                selectedSubSkillId = null;
            }
        });

        // ── Sub-Skill Dropdown ──
        $('#selectSubSkill').dxSelectBox({
            displayExpr: 'SubSkillName',
            valueExpr: 'SubSkillId',
            placeholder: 'Choose sub-skill...',
            stylingMode: 'outlined',
            onValueChanged: function (e) {
                selectedSubSkillId = e.value;
            }
        });

        // ── Available Day (single day, same options as registration but no multi-select) ──
        $('#selectDay').dxSelectBox({
            dataSource: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
            placeholder: 'Choose day...',
            stylingMode: 'outlined'
        });

        // ── Preferred start / end time ──
        $('#preferredStart').dxDateBox({
            type: 'time',
            placeholder: 'Start time',
            pickerType: 'list'
        });

        $('#preferredEnd').dxDateBox({
            type: 'time',
            placeholder: 'End time',
            pickerType: 'list'
        });

        // ── Search Button ──
        $('#btnSearch').dxButton({
            text: 'Find Helpers',
            type: 'default',
            icon: 'find',
            width: '100%',
            stylingMode: 'contained',
            onClick: function () {
                const fId  = $('#selectField').dxSelectBox('instance').option('value');
                const sId  = $('#selectSkill').dxSelectBox('instance').option('value');
                const subId = selectedSubSkillId;
                const dayInst = $('#selectDay').dxSelectBox('instance');
                const startInst = $('#preferredStart').dxDateBox('instance');
                const endInst = $('#preferredEnd').dxDateBox('instance');
                const day = dayInst ? dayInst.option('value') : '';
                const startVal = startInst ? startInst.option('value') : null;
                const endVal = endInst ? endInst.option('value') : null;
                const timeStart = startVal && startVal instanceof Date ? startVal.toTimeString().slice(0, 8) : (startVal || '');
                const timeEnd = endVal && endVal instanceof Date ? endVal.toTimeString().slice(0, 8) : (endVal || '');

                if (!subId) {
                    DevExpress.ui.notify('Please select a field, skill, and sub-skill first.', 'warning', 2500);
                    return;
                }
                lastSearch = { fieldId: fId, skillId: sId, subSkillId: subId, timeStart, timeEnd, day };
                findHelpers(fId, sId, subId, timeStart, timeEnd, day);
            }
        });

        function showStatus(icon, text) {
            const banner = document.getElementById('statusBanner');
            document.getElementById('statusIcon').textContent = icon;
            document.getElementById('statusText').textContent = text;
            banner.style.display = 'flex';
        }

        function hideStatus() {
            document.getElementById('statusBanner').style.display = 'none';
        }

        function findHelpers(fId, sId, subId, timeStart, timeEnd, day) {
            showStatus('🔍', 'Searching for qualified helpers...');
            document.getElementById('resultsSection').style.display = 'none';
            const q = new URLSearchParams({ fieldId: fId, skillId: sId, subSkillId: subId });
            if (timeStart) q.set('timeStart', timeStart);
            if (timeEnd) q.set('timeEnd', timeEnd);
            if (day) q.set('availableDay', day);

            fetch('/User/GetRankedHelpers?' + q.toString())
                .then(r => r.json())
                .then(helpers => {
                    hideStatus();
                    renderHelpers(helpers || [], subId);
                });
        }

        function renderHelpers(helpers, subId) {
            const section = document.getElementById('resultsSection');
            const grid    = document.getElementById('helpersGrid');
            const count   = document.getElementById('helperCount');

            section.style.display = 'block';
            count.textContent = helpers.length === 0 ? 'No user available' : helpers.length + ' found';

            if (!helpers.length) {
                grid.innerHTML = `
                    <div class="no-helpers">
                        <div class="icon">😕</div>
                        <p><strong>No user available.</strong><br>
                        No helpers are available for this skill at the selected time. Try a different day, time, or sub-skill.</p>
                    </div>`;
                return;
            }

            grid.innerHTML = helpers.map((h, i) => {
                const initial = (h.username || '?')[0].toUpperCase();
                const hes = (h.hes != null ? h.hes : h.HES) != null ? Number(h.hes || h.HES).toFixed(2) : '—';
                const safeName = (h.username || 'Unknown').replace(/'/g, "\\'");
                return `
                <div class="helper-card ${i === 0 ? 'top-pick' : ''}">
                    <div class="helper-rank">#${i + 1} Helper</div>
                    <div class="helper-name">
                        <div class="helper-avatar">${initial}</div>
                        ${h.username || 'Unknown'}
                    </div>
                    <div class="helper-skill-info">
                        <span class="badge-level level-4">Score ${hes}</span>
                    </div>
                    <button class="request-btn" onclick="sendRequest(${h.userId}, '${safeName}', this)">
                        📨 Request Help
                    </button>
                </div>`;
            }).join('');
        }

        function sendRequest(helperId, helperName, btn) {
            btn.disabled = true;
            btn.textContent = 'Sending...';
            const s = lastSearch;
            const desc = document.getElementById('txtProblemDesc').value || '';
            const body = new URLSearchParams({
                helperId, fieldId: s.fieldId, skillId: s.skillId, subSkillId: s.subSkillId,
                timeStart: s.timeStart || '', timeEnd: s.timeEnd || '', availableDay: s.day || '', description: desc
            });

            fetch('/User/SendHelpRequest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            })
            .then(r => r.json())
            .then(function (data) {
                document.getElementById('requestedHelperName').textContent = helperName;
                document.getElementById('requestOverlay').classList.add('show');
                btn.textContent = '✓ Request Sent';
                window._lastSentHelperId = helperId;
                window._lastHelpRequestId = data.helpRequestId || 0;
                if (window._requestTimeout) clearTimeout(window._requestTimeout);
                window._requestTimeout = setTimeout(function () {
                    var s = lastSearch;
                    var q = 'fieldId=' + s.fieldId + '&skillId=' + s.skillId + '&subSkillId=' + s.subSkillId;
                    if (s.timeStart) q += '&timeStart=' + encodeURIComponent(s.timeStart);
                    if (s.timeEnd) q += '&timeEnd=' + encodeURIComponent(s.timeEnd);
                    if (s.day) q += '&availableDay=' + encodeURIComponent(s.day);
                    q += '&excludeHelperId=' + helperId;
                    fetch('/User/GetRankedHelpers?' + q).then(function (r) { return r.json(); }).then(function (list) {
                        if (list && list.length > 0) {
                            document.getElementById('nextHelperName').textContent = list[0].username || 'Next helper';
                            document.getElementById('nextHelperArea').style.display = 'block';
                            window._nextHelper = list[0];
                        }
                    });
                }, 120000);
            });
        }

        $('#sendToNextBtn').on('click', function () {
            var next = window._nextHelper;
            var reqId = window._lastHelpRequestId;
            if (!next || !reqId) return;
            var s = lastSearch;
            var desc = document.getElementById('txtProblemDesc').value || '';
            fetch('/User/WithdrawRequest', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: 'helpRequestId=' + reqId })
                .then(function (r) { return r.json(); })
                .then(function (w) {
                    if (!w.success) return;
                    var body = new URLSearchParams({
                        helperId: next.userId, fieldId: s.fieldId, skillId: s.skillId, subSkillId: s.subSkillId,
                        timeStart: s.timeStart || '', timeEnd: s.timeEnd || '', availableDay: s.day || '', description: desc
                    });
                    return fetch('/User/SendHelpRequest', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() });
                })
                .then(function (r) { return r && r.json ? r.json() : null; })
                .then(function (data) {
                    if (data && data.success) {
                        document.getElementById('requestedHelperName').textContent = next.username || 'Next helper';
                        document.getElementById('nextHelperArea').style.display = 'none';
                        window._lastHelpRequestId = data.helpRequestId || 0;
                        window._lastSentHelperId = next.userId;
                    }
                });
        });
    </script>
}
