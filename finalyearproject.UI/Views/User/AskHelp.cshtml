@{
    ViewData["Title"] = "Ask for Help";
    Layout = "_Layout";
}

<style>
    .askhelp-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    .page-header {
        margin-bottom: 28px;
    }

        .page-header h2 {
            color: #e8f4f8;
            font-size: 1.7rem;
            font-weight: 700;
            margin: 0 0 6px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-header p {
            color: #6b8fa8;
            margin: 0;
            font-size: 0.9rem;
        }

    /* ── Step Card ── */
    .step-card {
        background: #16213e;
        border: 1px solid rgba(124,58,237,0.25);
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 20px;
    }

    .step-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #7c3aed;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .step-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(124,58,237,0.2);
        }

    .step-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        align-items: end;
    }

    .form-group label {
        display: block;
        color: #6b8fa8;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    .dx-selectbox-container, .dx-widget {
        border-radius: 8px !important;
    }

    /* ── Search Button ── */
    .search-btn-wrap {
        display: flex;
        align-items: flex-end;
    }

    /* ── Status Banner ── */
    .status-banner {
        background: rgba(124,58,237,0.1);
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: 10px;
        padding: 12px 18px;
        color: #a78bfa;
        font-size: 0.85rem;
        margin-bottom: 20px;
        display: none;
        align-items: center;
        gap: 10px;
    }

    /* ── Results Section ── */
    .results-section {
        display: none;
    }

    .results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .results-title {
        color: #e8f4f8;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .results-count {
        background: rgba(124,58,237,0.15);
        color: #a78bfa;
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 0.8rem;
    }

    /* ── Helper Cards ── */
    .helpers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 16px;
    }

    .helper-card {
        background: #16213e;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 20px;
        transition: border-color 0.2s, transform 0.2s;
        position: relative;
        overflow: hidden;
    }

        .helper-card.top-pick {
            border-color: rgba(124,58,237,0.5);
            box-shadow: 0 0 0 1px rgba(124,58,237,0.2);
        }

            .helper-card.top-pick::before {
                content: '⭐ Best Match';
                position: absolute;
                top: 0;
                right: 0;
                background: #7c3aed;
                color: white;
                font-size: 0.65rem;
                font-weight: 700;
                padding: 4px 12px;
                border-bottom-left-radius: 10px;
            }

        .helper-card:hover {
            border-color: rgba(124,58,237,0.4);
            transform: translateY(-2px);
        }

    .helper-rank {
        font-size: 0.7rem;
        color: #6b8fa8;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    .helper-name {
        color: #e8f4f8;
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 2px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .helper-avatar {
        width: 28px;
        height: 28px;
        background: linear-gradient(135deg, #7c3aed, #a78bfa);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        color: white;
    }

    .helper-skill-info {
        color: #6b8fa8;
        font-size: 0.82rem;
        margin: 8px 0 12px;
    }

    .badge-level {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
        display: inline-block;
    }

    .level-1 {
        background: rgba(107,140,168,0.15);
        color: #6b8fa8;
        border: 1px solid #6b8fa8;
    }

    .level-2 {
        background: rgba(96,165,250,0.15);
        color: #60a5fa;
        border: 1px solid #60a5fa;
    }

    .level-3 {
        background: rgba(167,139,250,0.15);
        color: #a78bfa;
        border: 1px solid #a78bfa;
    }

    .level-4 {
        background: rgba(52,211,153,0.15);
        color: #34d399;
        border: 1px solid #34d399;
    }

    .request-btn {
        width: 100%;
        background: #7c3aed;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, opacity 0.2s;
        margin-top: 12px;
    }

        .request-btn:hover {
            background: #6d28d9;
        }

        .request-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* ── Empty/Loading States ── */
    .no-helpers {
        background: #16213e;
        border: 2px dashed rgba(255,255,255,0.1);
        border-radius: 14px;
        padding: 48px 20px;
        text-align: center;
        color: #6b8fa8;
        grid-column: 1 / -1;
    }

        .no-helpers .icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

    /* ── Request Sent Modal ── */
    .request-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(4px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .request-overlay.show {
            display: flex;
        }

    .request-modal {
        background: #16213e;
        border: 1px solid rgba(124,58,237,0.4);
        border-radius: 18px;
        padding: 36px 40px;
        text-align: center;
        max-width: 400px;
        animation: popIn 0.25s ease;
    }

    @@keyframes popIn {
        from {
            transform: scale(0.85);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .request-modal h4 {
        color: #e8f4f8;
        margin: 0 0 8px;
    }

    .request-modal p {
        color: #6b8fa8;
        font-size: 0.88rem;
        margin: 0 0 20px;
    }

    .modal-close-btn {
        background: #7c3aed;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 28px;
        font-weight: 600;
        cursor: pointer;
    }
</style>

<div class="askhelp-wrapper">

    <!-- ── Header ── -->
    <div class="page-header">
        <h2> Ask for Help</h2>
        <p>Find a verified expert who can help you. Select a skill and we'll match you with the best helpers.</p>
    </div>

    <!-- ── Selection Step ── -->
    <div class="step-card">
        <div class="step-label">Step 1 — Choose the Skill You Need Help With</div>
        <div class="step-grid">
            <div class="form-group">
                <label>Field</label>
                <div id="selectField"></div>
            </div>
            <div class="form-group">
                <label>Skill</label>
                <div id="selectSkill"></div>
            </div>
            <div class="form-group">
                <label>Sub-Skill</label>
                <div id="selectSubSkill"></div>
            </div>
            <div class="form-group">
                <label>Available Day</label>
                <div id="selectDay"></div>
            </div>
            <div class="form-group">
                <label>Preferred Time (From)</label>
                <div id="preferredStart"></div>
            </div>
            <div class="form-group">
                <label>Preferred Time (To)</label>
                <div id="preferredEnd"></div>
            </div>
            <div class="form-group search-btn-wrap">
                <div id="btnSearch" style="width:100%;"></div>
            </div>
        </div>
        <div class="form-group mt-3">
            <label>Problem Description</label>
            <textarea id="txtProblemDesc" class="form-control" rows="3" placeholder="Describe what you need help with..." style="background:#0a0f1d;border:1px solid rgba(255,255,255,0.2);color:#fff;border-radius:8px;"></textarea>
        </div>
    </div>

    <!-- ── Status Banner ── -->
    <div class="status-banner" id="statusBanner">
        <span id="statusIcon">🔍</span>
        <span id="statusText">Searching for helpers...</span>
    </div>

    <!-- ── Results ── -->
    <div class="results-section" id="resultsSection">
        <div class="results-header">
            <div class="results-title">
                Matching Helpers
                <span class="results-count" id="helperCount">0 found</span>
            </div>
            <span style="color:#6b8fa8;font-size:0.8rem;">Sorted by experience level</span>
        </div>
        <div class="helpers-grid" id="helpersGrid"></div>
    </div>

</div>

<!-- ── Request Sent Overlay ── -->
<div class="request-overlay" id="requestOverlay">
    <div class="request-modal">
        <h4>Request Sent!</h4>
        <p>
            Your request has been sent to <strong id="requestedHelperName">the helper</strong>.<br>
            They will see it under <strong>My Requests</strong> with Accept / Reject. After they accept, you can chat there.
        </p>
        <p class="small text-muted mb-2">If no response in 2 minutes, the request is auto-cancelled so you can choose another helper.</p>
        <div id="nextHelperArea" style="display:none; margin-bottom:12px;">
            <p class="small mb-1">Helper didn't respond. Send to next: <strong id="nextHelperName"></strong>?</p>
            <button type="button" class="btn btn-sm btn-primary" id="sendToNextBtn">Send to this helper</button>
        </div>
        <button type="button" class="modal-close-btn mb-2" id="cancelRequestBtn" style="background:rgba(245,101,101,0.15);border:1px solid rgba(245,101,101,0.35);">
            Cancel this request
        </button>
        <a href="/User/MyHelpRequests" class="modal-close-btn mb-2 d-inline-block text-decoration-none text-center">View My Requests</a>
        <button class="modal-close-btn" onclick="document.getElementById('requestOverlay').classList.remove('show');">
            Got it
        </button>
    </div>
</div>

@section Scripts {
    <script src="~/js/askHelp.js"></script>
}
