@{
    ViewData["Title"] = "Professional Peer-to-Peer Help";
}

<section class="py-5 position-relative">
    <div class="container py-5 mt-4">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-right">
                <div class="d-inline-flex align-items-center rounded-pill px-3 py-1 mb-4" style="background: rgba(124, 58, 237, 0.15); border: 1px solid rgba(124, 58, 237, 0.3);">
                    <span style="color: #a78bfa; font-size: 0.85rem; font-weight: 600;">Verified Talent Ecosystem</span>
                </div>
                <h1 class="display-3 mb-4">
                    Verified Peer-to-Peer <br />
                    <span style="background: linear-gradient(90deg, #a78bfa, #7c3aed); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Skill Assistance</span>
                </h1>
                <p class="mb-5 fs-5">
                    Empowering users to master new technologies through collaborative learning.
                    Our system connects you with verified peers to solve real-world problems
                    and build a professional ranking through shared knowledge.
                </p>
                <div class="d-flex gap-3">
                    <a href="#process"  class="btn btn-main px-4 py-3">Explore System</a>
                </div>
            </div>
            <div class="col-lg-6" data-aos="zoom-in">
                <div class="position-relative p-2 rounded-5" style="background: linear-gradient(45deg, rgba(124, 58, 237, 0.2), transparent);">
                    <img src="~/Content/peer-support.jpeg" class="img-fluid rounded-5 shadow-2xl" alt="Peer Collaboration" style="width:100%; object-fit: cover; border: 1px solid rgba(255,255,255,0.1);">
                </div>
            </div>
        </div>
    </div>
</section>

<section id="process" class="py-5 bg-dark">
    
    
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <h2 class="display-5 fw-bold mb-4">A Growing Community</h2>
                <p class="text-white-50 fs-5 mb-4">Collaborate with thousands of active learners and experts. Our ecosystem thrives on direct interaction and mutual growth.</p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-4 rounded-4 bg-secondary bg-opacity-10 border border-secondary border-opacity-20 text-center">
                            <h3 class="fw-bold mb-0 text-primary">10k+</h3>
                            <p class="small mb-0 opacity-50">Active Users</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-4 bg-secondary bg-opacity-10 border border-secondary border-opacity-20 text-center">
                            <h3 class="fw-bold mb-0 text-primary">500+</h3>
                            <p class="small mb-0 opacity-50">Skill Sets</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-6">
                        <img src="~/Content/image1.png" class="img-fluid rounded-4 shadow-lg mb-3" alt="Meeting" style="height: 400px; object-fit: cover; width: 100%;">
                    </div>
                    <div class="col-6">
                        <img src="~/Content/image2.png" class="img-fluid rounded-4 shadow-lg mb-3" alt="Workshop" style="height: 190px; object-fit: cover; width: 100%;">
                        <img src="~/Content/image3.png" class="img-fluid rounded-4 shadow-lg" alt="Matching" style="height: 190px; object-fit: cover; width: 100%;">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-md-4" data-aos="fade-right">
                <div class="p-5 rounded-5 h-100" style="background: #0f172a;">
                    <h3 class="h4 mb-4">Seeker</h3>
                    <p class="small mb-4">Match with top-tier helpers for granular sub-skills and grow your knowledge faster.</p>
                    <a href="#" class="text-primary text-decoration-none fw-bold small">Explore Flow →</a>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up">
                <div class="p-5 rounded-5 h-100 border border-primary border-opacity-20">
                    <h3 class="h4 mb-4">Helper</h3>
                    <p class="small mb-4">Share your verified expertise, earn points, and build your professional ranking.</p>
                    <a href="#" class="text-primary text-decoration-none fw-bold small">Earn Points →</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background: rgba(124, 58, 237, 0.02);">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-bold">Questions &amp; answers</h2>
            <p class="text-white-50">More common questions about PeerAssist — how matching, sessions, and your account work.</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion accordion-flush" id="faqAccordion">
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How does the matching system work?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                You choose a field, skill, and sub-skill, plus when you are free. We list verified helpers who teach that exact sub-skill, are available in that window, and are not already busy. They are ranked using a score (HES) that blends responsiveness, ratings, and experience — so “Best Match” reflects quality, not random order.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                Is my data secure during sessions?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                Accounts use secure sign-in and email verification (OTP) where enabled. Chat messages are protected for storage so plain text is not exposed casually in the database. Only the people in that help request should see the conversation in the app.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Why can’t I ask another helper while one request is still pending?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                You can only have one active “seeker” flow at a time: either waiting on a helper, already in a session, or helping someone else. Complete or cancel your current request under <strong>My Requests</strong> (or wait for a timeout where applicable), then you can search and ask someone else.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                How long does a helper have to respond?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                Helpers are expected to respond within about <strong>two minutes</strong>. If there is no response, the pending request can be released so you are free to choose another helper without staying stuck.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                                Can I be both a seeker and a helper?
                            </button>
                        </h2>
                        <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                Yes — add the skills you can teach and use <strong>Ask for Help</strong> when you need support. The platform only allows <strong>one busy state at a time</strong> (for example, you cannot stack multiple outgoing requests or overlap incompatible states), which keeps the experience fair for everyone.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq6">
                                What happens after a session ends?
                            </button>
                        </h2>
                        <div id="faq6" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                The seeker marks the session completed or not completed and can rate the helper. That feedback feeds into future matching. Points and profile stats update so good helpers stay visible.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq7">
                                How do I cancel a request I sent?
                            </button>
                        </h2>
                        <div id="faq7" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                Open <strong>My Requests</strong> as a seeker. You can withdraw a pending request from there. After it is cleared, you can run a new search on <strong>Ask for Help</strong>.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-transparent border-bottom border-secondary border-opacity-25 py-3">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-transparent text-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq8">
                                Why might a helper not appear for a skill I also have?
                            </button>
                        </h2>
                        <div id="faq8" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-white-50">
                                If you already list that exact field, skill, and sub-skill on your profile, we only show helpers whose <strong>experience level is the same or higher</strong> than yours for that row — so you are not matched with someone more junior for a topic you already know at a senior level.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container py-5">
        <div class="p-5 rounded-5 text-center shadow-2xl" style="background: linear-gradient(135deg, #1e1b4b, #0a0f1d); border: 1px solid rgba(255,255,255,0.05);">
            <h2 class="display-5 mb-4">Ready to Explore?</h2>
            <p class="mb-5 mx-auto opacity-75" style="max-width: 600px;">Join the network where skills are measured by peer results, not just claims.</p>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="alert alert-info d-inline-block mb-0" style="background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.3); color: #a78bfa; border-radius: 10px;">
                    You're already logged in as <strong>@User.Identity.Name</strong>. Logout to register a new account.
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light px-5 py-3">Logout to Register</button>
                </form>
            }
            else
            {
                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Register" asp-controller="Account" class="btn btn-main px-5 py-3">User Registration</a>
                </div>
            }
        </div>
    </div>
</section>