@* @{
    ViewData["Title"] = "About - Peer Help System";
}

<div class="container py-5">
    <!-- About Header -->
    <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center">
            <h1 class="display-4 fw-bold mb-4 text-primary">About Peer Help System</h1>
            <p class="lead" style="color: #495057; line-height: 1.8;">
                Empowering students and professionals to connect, collaborate, and grow together through shared knowledge and skills.
            </p>
        </div>
    </div>

    <!-- Mission Section -->
    <div class="row mb-5 align-items-center">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-bullseye text-primary me-3" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                            <path d="M8 13A5 5 0 1 1 8 3a5 5 0 0 1 0 10m0 1A6 6 0 1 0 8 2a6 6 0 0 0 0 12" />
                            <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6m0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8" />
                            <path d="M9.5 8a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
                        </svg>
                        <h2 class="mb-0 fw-bold">Our Mission</h2>
                    </div>
                    <p class="mb-0" style="color: #495057; line-height: 1.8;">
                        To create a supportive community where individuals can share their expertise, learn from others,
                        and build meaningful professional relationships. We believe in the power of peer-to-peer learning
                        and collaborative problem-solving.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-eye text-primary me-3" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                        </svg>
                        <h2 class="mb-0 fw-bold">Our Vision</h2>
                    </div>
                    <p class="mb-0" style="color: #495057; line-height: 1.8;">
                        To become the go-to platform for peer support and skill-sharing across educational institutions
                        and professional networks. We envision a world where knowledge is freely shared, and everyone has
                        access to the help they need to succeed.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- What We Offer Section -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="text-center mb-4">
                <h2 class="fw-bold mb-3" style="font-size: 2.5rem; color: #2c3e50;">What We Offer</h2>
                <p class="lead text-muted">Comprehensive features designed to facilitate meaningful collaboration</p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-people text-primary" viewBox="0 0 16 16">
                            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4" />
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-3">Skill Matching</h5>
                    <p class="text-muted mb-0">Connect with peers who have the exact skills you're looking for, or offer your own expertise to those who need it.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-file-earmark-person text-primary" viewBox="0 0 16 16">
                            <path d="M11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0" />
                            <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2v9.75a.75.75 0 0 1-.75.75h-8.5A.75.75 0 0 1 3 14.25V2.75A.75.75 0 0 1 3.75 2h5.75z" />
                            <path d="M3 12.75v-.75a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v.75z" />
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-3">Portfolio Building</h5>
                    <p class="text-muted mb-0">Upload your CV and showcase your skills, creating a professional portfolio that helps you stand out.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-shield-check text-primary" viewBox="0 0 16 16">
                            <path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56" />
                            <path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0" />
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-3">Secure & Verified</h5>
                    <p class="text-muted mb-0">Email verification and admin approval ensure a trusted community of genuine helpers and learners.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-calendar-check text-primary" viewBox="0 0 16 16">
                            <path d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0" />
                            <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z" />
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-3">Availability Tracking</h5>
                    <p class="text-muted mb-0">Find helpers based on their actual availability, making it easier to connect at the right time.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-chat-dots text-primary" viewBox="0 0 16 16">
                            <path d="M5 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0m4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0m3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2" />
                            <path d="m2.165 15.803.02-.004c1.83-.363 2.948-.842 3.468-1.105A9 9 0 0 0 8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6a10.4 10.4 0 0 1-.524 2.318l-.003.011a11 11 0 0 1-.244.637c-.079.186.074.394.273.362a22 22 0 0 0 .693-.125m.8-3.108a1 1 0 0 0-.287-.801C1.618 10.83 1 9.468 1 8c0-3.192 3.004-6 7-6s7 2.808 7 6-3.004 6-7 6a8 8 0 0 1-2.088-.272 1 1 0 0 0-.711.074c-.387.196-1.24.57-2.634.893a11 11 0 0 0 .398-2" />
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-3">Easy Communication</h5>
                    <p class="text-muted mb-0">Simple and intuitive interface to connect, discuss projects, and collaborate effectively.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-graph-up-arrow text-primary" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M0 0h1v15h15v1H0zm10 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V4.9l-3.613 4.417a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61L13.445 4H10.5a.5.5 0 0 1-.5-.5" />
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-3">Track Your Growth</h5>
                    <p class="text-muted mb-0">Monitor your contributions, build your reputation, and showcase your impact within the community.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- How It Works Section -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body p-5 text-white">
                    <h2 class="text-center fw-bold mb-5">How It Works</h2>
                    <div class="row g-4">
                        <div class="col-md-3 text-center">
                            <div class="mb-3">
                                <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <span class="fw-bold text-primary" style="font-size: 2rem;">1</span>
                                </div>
                            </div>
                            <h5 class="fw-bold mb-2">Register</h5>
                            <p class="mb-0 opacity-75">Create your account with email verification</p>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="mb-3">
                                <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <span class="fw-bold text-primary" style="font-size: 2rem;">2</span>
                                </div>
                            </div>
                            <h5 class="fw-bold mb-2">Add Skills</h5>
                            <p class="mb-0 opacity-75">Upload your CV and list your expertise</p>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="mb-3">
                                <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <span class="fw-bold text-primary" style="font-size: 2rem;">3</span>
                                </div>
                            </div>
                            <h5 class="fw-bold mb-2">Connect</h5>
                            <p class="mb-0 opacity-75">Find helpers or offer your assistance</p>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="mb-3">
                                <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <span class="fw-bold text-primary" style="font-size: 2rem;">4</span>
                                </div>
                            </div>
                            <h5 class="fw-bold mb-2">Collaborate</h5>
                            <p class="mb-0 opacity-75">Work together and grow your skills</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="row">
        <div class="col-lg-8 mx-auto text-center">
            <h2 class="fw-bold mb-4">Join Our Community Today</h2>
            <p class="lead mb-4 text-muted">
                Whether you're looking for help or ready to share your knowledge, the Peer Help System is here to support your journey.
            </p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-5 py-3 shadow">
                Get Started Now
            </a>
        </div>
    </div>
</div> *@

@{
    ViewData["Title"] = "About Us";
}

<section class="py-5 mt-5" data-aos="fade-up">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h6 class="text-uppercase fw-bold mb-3" style="color: #7c3aed; letter-spacing: 2px;">Our Mission</h6>
                <h1 class="display-4 fw-bold mb-4">Empowering Peers Through <span style="color: #a78bfa;">Knowledge Exchange</span></h1>
                <p class="lead text-white-50">
                    PeerAssist was built on the belief that the best way to grow is together. We provide a structured ecosystem where technical expertise meets real-world needs.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="p-4 rounded-5" style="background: rgba(124, 58, 237, 0.05); border: 1px solid rgba(124, 58, 237, 0.2);">
                    <div class="row g-4 text-center">
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">99%</h2>
                            <p class="small text-white-50 uppercase">User Satisfaction</p>
                        </div>
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">24/7</h2>
                            <p class="small text-white-50 uppercase">Global Support</p>
                        </div>
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">Verified</h2>
                            <p class="small text-white-50 uppercase">Skill Hierarchy</p>
                        </div>
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">Secure</h2>
                            <p class="small text-white-50 uppercase">Data Protection</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5 pt-5 g-4 text-center">
            <div class="col-md-4">
                <div class="p-5 rounded-4 h-100" style="background: #161b2c;">
                    <i class="bi bi-shield-check fs-1 text-primary mb-4"></i>
                    <h4 class="mb-3">Quality First</h4>
                    <p class="small text-white-50">Every user is vetted to ensure that the assistance provided remains high-tier and professional.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-5 rounded-4 h-100" style="background: #161b2c;">
                    <i class="bi bi-graph-up-arrow fs-1 text-primary mb-4"></i>
                    <h4 class="mb-3">Growth Mindset</h4>
                    <p class="small text-white-50">Our ranking system encourages helpers to provide quality sessions to build their industry brand.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-5 rounded-4 h-100" style="background: #161b2c;">
                    <i class="bi bi-people fs-1 text-primary mb-4"></i>
                    <h4 class="mb-3">Community Driven</h4>
                    <p class="small text-white-50">We focus on bridging the gap between experienced pros and those looking to level up.</p>
                </div>
            </div>
        </div>
    </div>
</section>

