@{
    ViewData["Title"] = "About Us";
}

<section class="py-5 mt-5" data-aos="fade-up">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h6 class="text-uppercase fw-bold mb-3" style="color: #7c3aed; letter-spacing: 2px;">Our Mission</h6>
                <h1 class="display-4 fw-bold mb-4">Empowering Peers Through <span style="color: #a78bfa;">Knowledge Exchange</span></h1>
                <p class="lead text-white-50">
                    PeerAssist was built on the belief that the best way to grow is together. We provide a structured ecosystem where technical expertise meets real-world needs.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="p-4 rounded-5" style="background: rgba(124, 58, 237, 0.05); border: 1px solid rgba(124, 58, 237, 0.2);">
                    <div class="row g-4 text-center">
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">99%</h2>
                            <p class="small text-white-50 uppercase">User Satisfaction</p>
                        </div>
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">24/7</h2>
                            <p class="small text-white-50 uppercase">Global Support</p>
                        </div>
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">Verified</h2>
                            <p class="small text-white-50 uppercase">Skill Hierarchy</p>
                        </div>
                        <div class="col-6">
                            <h2 class="fw-bold mb-0">Secure</h2>
                            <p class="small text-white-50 uppercase">Data Protection</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5 pt-5 g-4 text-center">
            <div class="col-md-4">
                <div class="p-5 rounded-4 h-100" style="background: #161b2c;">
                    <i class="bi bi-shield-check fs-1 text-primary mb-4"></i>
                    <h4 class="mb-3">Quality First</h4>
                    <p class="small text-white-50">Every user is vetted to ensure that the assistance provided remains high-tier and professional.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-5 rounded-4 h-100" style="background: #161b2c;">
                    <i class="bi bi-graph-up-arrow fs-1 text-primary mb-4"></i>
                    <h4 class="mb-3">Growth Mindset</h4>
                    <p class="small text-white-50">Our ranking system encourages helpers to provide quality sessions to build their industry brand.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-5 rounded-4 h-100" style="background: #161b2c;">
                    <i class="bi bi-people fs-1 text-primary mb-4"></i>
                    <h4 class="mb-3">Community Driven</h4>
                    <p class="small text-white-50">We focus on bridging the gap between experienced pros and those looking to level up.</p>
                </div>
            </div>
        </div>
    </div>
</section>

