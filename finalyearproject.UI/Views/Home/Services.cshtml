@{
    ViewData["Title"] = "Our Services";
}

<section class="py-5 mt-5">
    <div class="container py-5">
        <div class="text-center mb-5" data-aos="fade-down">
            <h1 class="display-5 fw-bold mb-3">Professional Services</h1>
            <p class="text-white-50 mx-auto" style="max-width: 700px;">
                Advanced tools designed for granular technical exchange and validated professional growth.
            </p>
        </div>

        <div class="row g-5 mt-4">
            <div class="col-lg-12" data-aos="fade-up">
                <div class="row align-items-center g-0 rounded-5 overflow-hidden" style="background: #161b2c; border: 1px solid rgba(255,255,255,0.05);">
                    <div class="col-md-6">
                        <img src="~/Content/service image1.png" class="img-fluid h-100 w-100" style="object-fit: cover; min-height: 400px;" alt="Skill Discovery">
                    </div>
                    <div class="col-md-6 p-5">
                        <div class="mb-4 d-inline-block p-3 rounded-4" style="background: rgba(124, 58, 237, 0.1);">
                            <i class="bi bi-cpu fs-2 text-primary"></i>
                        </div>
                        <h2 class="fw-bold mb-4">Precision Skill Discovery</h2>
                        <p class="text-white-50 fs-5 mb-4">
                            Our system bypasses generic search. We map expertise to the micro-level, ensuring you find the exact person who can solve your technical bottleneck.
                        </p>
                        <div class="d-flex gap-4">
                            <div><strong class="text-white d-block">98%</strong><span class="small opacity-50">Match Accuracy</span></div>
                            <div class="vr opacity-25"></div>
                            <div><strong class="text-white d-block">Instant</strong><span class="small opacity-50">Peer Connection</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 p-5 rounded-5 text-center" style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.1);">
            <h4 class="fw-bold text-white mb-3">Professional Support Network</h4>
            <p class="text-white-50 mb-0">Direct Inquiry Line: <span class="text-primary fw-bold">9866836520</span></p>
            
        </div>
    </div>
</section>
