@model finalyearproject.UI.Models.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background: #161b2c;">
            <div class="card-header border-0 py-4 text-center" style="background: rgba(124, 58, 237, 0.1);">
                <h2 class="h3 mb-0 fw-bold text-white">Join the Network</h2>
                <p class="text-white-50 small mb-0">Create your account — skills can be added later from your profile</p>
            </div>
            <div class="card-body p-5">
                <form asp-action="Register" method="post" id="registerForm">
                    @Html.AntiForgeryToken()
                    <div id="ValidationSummary"></div>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small border-0 bg-danger bg-opacity-10 text-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label small text-white-50 fw-bold">Username</label>
                            <div id="txtUsername"></div>
                            <input type="hidden" asp-for="Username" id="hiddenUsername" />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label small text-white-50 fw-bold">Email Address</label>
                            <div id="txtEmail"></div>
                            <input type="hidden" asp-for="Email" id="hiddenEmail" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small text-white-50 fw-bold">Phone Number</label>
                        <div id="txtPhone"></div>
                        <input type="hidden" asp-for="PhoneNumber" id="hiddenPhone" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label small text-white-50 fw-bold">Password</label>
                            <div id="txtPassword"></div>
                            <input type="hidden" asp-for="Password" id="hiddenPassword" />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label small text-white-50 fw-bold">Confirm Password</label>
                            <div id="txtConfirmPassword"></div>
                            <input type="hidden" asp-for="ConfirmPassword" id="hiddenConfirmPassword" />
                        </div>
                    </div>

                    <div class="d-grid mt-3">
                        <div id="btnRegister"></div>
                    </div>
                </form>

                <div class="text-center mt-5 pt-3 border-top border-secondary border-opacity-10">
                    <p class="text-white-50 small mb-0">Already have a verified account? <a asp-action="Login" class="text-decoration-none" style="color: #a78bfa;">Sign in</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/register.js"></script>
}
