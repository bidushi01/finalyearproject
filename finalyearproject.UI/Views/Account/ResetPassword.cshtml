@model finalyearproject.UI.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    // ✅ FIX: Detect token type from ViewBag (set by controller)
    // If ViewBag.IsAdminReset is true, post to ResetAdminPassword
    bool isAdminReset = ViewBag.IsAdminReset == true;
    string formAction = isAdminReset ? "ResetAdminPassword" : "ResetPassword";
}

<style>
    body {
        background-color: #0a0f1d;
        color: #ffffff;
    }

    .custom-card {
        background: #161b2c;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 2rem;
    }

    .custom-card-header {
        background: linear-gradient(135deg, #1e1b4b, #0a0f1d);
        border-bottom: 1px solid rgba(124, 58, 237, 0.3);
        border-top-left-radius: 2rem !important;
        border-top-right-radius: 2rem !important;
        padding: 2.5rem;
    }

    .form-control {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 2px solid rgba(124, 58, 237, 0.4) !important;
        color: #ffffff !important;
        border-radius: 0.75rem !important;
    }

        .form-control:focus {
            border-color: #a78bfa !important;
            box-shadow: 0 0 0 0.2rem rgba(167, 139, 250, 0.25) !important;
        }

    .form-label {
        color: #c4b5fd;
        font-weight: 600;
    }

    .btn-reset {
        background: linear-gradient(90deg, #a78bfa, #7c3aed);
        border: none;
        color: white !important;
        font-weight: 700;
        padding: 1rem;
        border-radius: 0.75rem;
        width: 100%;
    }

        .btn-reset:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(124, 58, 237, 0.3);
        }

    .validation-summary-errors {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 1.5rem;
        }

        .validation-summary-errors li {
            color: #fca5a5;
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card custom-card shadow-lg">
                <div class="custom-card-header text-center">
                    <h2 class="fw-bold mb-0">Reset Password</h2>
                    <p class="text-white-50 mt-2">
                        @(isAdminReset ? "Admin Account" : "Set your new password")
                    </p>
                </div>
                <div class="card-body p-4 p-md-5">

                    @* ✅ FIX: Validation Summary shown inline (not redirect) *@
                    <div asp-validation-summary="All" class="validation-summary-errors"></div>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger rounded-3 border-0 mb-4" style="background: rgba(239,68,68,0.15);">
                            @TempData["ErrorMessage"]
                        </div>
                    }

                    @* ✅ FIX: form action dynamically set based on token type *@
                    <form asp-action="@formAction" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Token" />

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label">New Password</label>
                            <input asp-for="NewPassword" class="form-control" type="password"
                                   placeholder="Enter new password (min 6 chars)" />
                            <span asp-validation-for="NewPassword" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password"
                                   placeholder="Re-enter new password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                        </div>

                        <button type="submit" class="btn btn-reset mt-2">
                            Reset Password
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-controller="Account" asp-action="Login"
                           class="text-white-50 text-decoration-none small">
                            ← Back to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

