@{
    ViewData["Title"] = "Manage Skills";
    var username = ViewBag.Username;
}

<style>
    body {
        background-color: #0a0f1d;
        color: #ffffff;
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    .card {
        background-color: #161b2c !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 15px !important;
    }
    .dx-texteditor-input, .form-control, input[type="text"] {
        color: #ffffff !important;
        -webkit-text-fill-color: #ffffff !important;
    }
    .dx-placeholder, ::placeholder { color: #aaaaaa !important; opacity: 1 !important; }
    .dx-overlay-content, .dx-dropdownlist-popup-wrapper, .dx-list {
        background-color: #1e263d !important;
        border: 1px solid #7c3aed !important;
    }
    .dx-list-item { color: #ffffff !important; }
    .dx-list-item.dx-state-hover { background-color: rgba(124, 58, 237, 0.3) !important; }
    input[type="file"]::file-selector-button {
        background-color: #1e263d; color: white; border: 1px solid #7c3aed;
        padding: 5px 15px; border-radius: 5px; cursor: pointer;
    }
    .form-control, .dx-texteditor {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(124, 58, 237, 0.4) !important;
    }
    .form-label, label, h5, .section-title { color: #ffffff !important; font-weight: 600 !important; }
    .custom-header {
        background-color: #1e263d !important;
        border-bottom: 2px solid #7c3aed;
        padding: 1.5rem;
        border-top-left-radius: 15px;
        border-top-right-radius: 15px;
    }
    .badge-pending { background: rgba(246,173,85,0.2); color: #f6ad55; }
    .badge-approved { background: rgba(72,187,120,0.2); color: #48bb78; }
    .badge-rejected { background: rgba(245,101,101,0.2); color: #f56565; }
    .badge-draft { background: rgba(147,197,253,0.2); color: #93c5fd; }
    #submitSection { background: rgba(246,173,85,0.08); border: 1px solid rgba(246,173,85,0.35); border-radius: 12px; padding: 1.25rem; }
</style>

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-10">
        <div class="card shadow-lg">
            <div class="custom-header text-center">
                <h3 class="fw-bold mb-0">Your Skills Portfolio</h3>
                <p class="mb-0 text-white-50">Hello, <strong>@username</strong>! Add skills to become a helper. Each skill is reviewed by admin using your CV.</p>
            </div>

            <div class="card-body p-4 p-lg-5">
                <div class="mb-5" id="cvSection">
                    <h5 class="section-title border-bottom pb-2">Professional Documents</h5>
                    <p class="small text-muted">Upload or update your CV so admin can verify skills you submit.</p>
                    <div class="row mt-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Upload CV</label>
                            <input type="file" id="cvUpload" class="form-control" accept=".pdf,.doc,.docx" />
                            <div id="cvStatus" class="mt-2 text-success"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Portfolio URL (Optional)</label>
                            <div id="txtPortfolio"></div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-outline-light btn-sm" id="btnSaveCvPortfolio">Save CV &amp; Portfolio</button>
                </div>

                <div id="addedSkillsList" class="mb-5">
                    <h5 class="section-title border-bottom pb-2">Your Skills Portfolio</h5>
                    <div id="skillsContainer" class="mt-2"></div>
                </div>

                <div class="p-4 rounded-3" style="background: rgba(255,255,255,0.02);">
                    <h5 class="mb-4" style="color: #a78bfa;">Add a New Skill Set</h5>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Field of Expertise</label>
                            <div id="ddField"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Primary Skill</label>
                            <div id="ddSkill"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Sub-Skill(s)</label>
                            <div id="ddSubSkill"></div>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Experience Level</label>
                            <div id="ddExperience"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Availability Days</label>
                            <div id="tagAvailableDays"></div>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-12">
                            <label class="form-label fw-bold">Availability times</label>
                            <p class="small text-muted mb-2">Each slot must end on the same day (e.g. 3:00 PM to 11:00 PM). Use another slot for a later break (e.g. 2:00 PM-5:00 PM and 9:00 PM-11:00 PM).</p>
                            <div id="timeSlotsList"></div>
                            <button type="button" class="btn btn-outline-light btn-sm mt-1" id="btnAddTimeSlot">+ Add another time slot</button>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-3">
                        <div id="btnAddSkill"></div>
                    </div>
                </div>

                <div id="submitSection" class="mt-4 mb-3">
                    <h5 class="section-title">Submit for admin verification</h5>
                    <p class="small text-muted mb-2">
                        Skills you add above are saved locally until you submit. They are not on your profile until admin approves each skill.
                        Upload your CV and click <strong>Save CV &amp; Portfolio</strong>, or submit below (selected CV file will upload automatically).
                    </p>
                    <p class="small mb-3"><span id="draftSkillCount">0</span> skill(s) ready to submit.</p>
                    <button type="button" class="btn btn-warning fw-bold" id="btnSubmitForAdminReview">
                        Submit skills for admin verification
                    </button>
                </div>

                <div class="mt-4 pt-3 border-top border-secondary">
                    <a asp-controller="User" asp-action="Profile" class="btn btn-outline-light">← Back to Profile</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.addSkillsConfig = { isLoggedInUser: true };
    </script>
    <script src="~/js/addskills.js" asp-append-version="true"></script>
}
