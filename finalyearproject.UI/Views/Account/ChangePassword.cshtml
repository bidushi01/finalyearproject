@model finalyearproject.UI.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}

<style>
    :root {
        --system-bg: #0a0e1a;
        --card-bg: #1c1f2e;
        --input-bg: #2b2f44;
        --primary-blue: #3b82f6;
        --text-muted: #94a3b8;
    }

    .password-page-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--system-bg);
    }

    .custom-card {
        background: var(--card-bg);
        border-radius: 12px;
        padding: 40px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .form-header {
        text-align: center;
        margin-bottom: 25px;
    }

        .form-header h2 {
            color: #ffffff;
            font-weight: 700;
        }

        .form-header p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

    .input-container {
        margin-bottom: 20px;
    }

        .input-container label {
            display: block;
            color: var(--text-muted);
            margin-bottom: 8px;
            font-size: 0.85rem;
        }

    .styled-input {
        width: 100%;
        padding: 12px;
        background: var(--input-bg);
        border: 1px solid #3e445e;
        border-radius: 8px;
        color: white;
    }

        .styled-input:focus {
            outline: none;
            border-color: var(--primary-blue);
        }

    .submit-btn {
        width: 100%;
        padding: 12px;
        background: var(--primary-blue);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
    }

    .validation-text {
        color: #f87171;
        font-size: 0.8rem;
        margin-top: 5px;
        display: block;
    }
</style>

<div class="password-page-wrapper">
    <div class="custom-card">
        <div class="form-header">
            <h2>Change Password</h2>
            <p>Update your PeerAssist security credentials</p>
        </div>

        <form asp-action="ChangePassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div class="input-container">
                <label asp-for="CurrentPassword">Current Password</label>
                <input asp-for="CurrentPassword" class="styled-input" type="password" />
                <span asp-validation-for="CurrentPassword" class="validation-text"></span>
            </div>

            <div class="input-container">
                <label asp-for="NewPassword">New Password</label>
                <input asp-for="NewPassword" class="styled-input" type="password" />
                <span asp-validation-for="NewPassword" class="validation-text"></span>
            </div>

            <div class="input-container">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="styled-input" type="password" />
                <span asp-validation-for="ConfirmPassword" class="validation-text"></span>
            </div>

            <button type="submit" class="submit-btn">Update Password</button>
        </form>
    </div>
</div>