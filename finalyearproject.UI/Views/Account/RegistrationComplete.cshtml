@{
    ViewData["Title"] = "Registration Complete";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header text-center text-white" style="background-color:#22c55e;">
                <h3 class="mb-0">Thank you for registering</h3>
            </div>
            <div class="card-body p-4 text-center">
                <p class="lead mb-3">Your details have been submitted successfully.</p>
                <p class="text-muted mb-4">
                    Please wait while an admin reviews your application.
                    You will receive an email once your account is approved.
                </p>
                <a asp-action="Login" class="btn btn-primary px-4">Go to Login</a>
            </div>
        </div>
    </div>
</div>

