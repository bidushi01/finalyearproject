@{
    ViewData["Title"] = "Pending Users";
    Layout = "_Layout";
}

<style>
    .page-wrapper {
        padding: 30px;
        max-width: 1300px;
        margin: 0 auto;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .stat-box {
        background: #16213e;
        border-radius: 14px;
        padding: 20px;
        border: 1px solid rgba(255,255,255,0.08);
        position: relative;
        overflow: hidden;
    }

        .stat-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: 14px 14px 0 0;
        }

        .stat-box.pending::before {
            background: #f6ad55;
        }

        .stat-box.approved::before {
            background: #48bb78;
        }

        .stat-box.rejected::before {
            background: #f56565;
        }

    .stat-number {
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #6b8fa8;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    #userGrid {
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
    }

    .dx-datagrid {
        background-color: #16213e !important;
        color: #c5d8e8 !important;
    }

    .dx-datagrid-headers {
        background-color: rgba(0,210,210,0.07) !important;
        border-bottom: 1px solid rgba(0,210,210,0.2) !important;
    }

        .dx-datagrid-headers td {
            color: #00d2d2 !important;
            font-size: 0.74rem !important;
            font-weight: 700 !important;
            text-transform: uppercase !important;
        }

    .dx-datagrid-rowsview .dx-row td {
        padding: 14px 16px !important;
        border-color: rgba(255,255,255,0.04) !important;
        color: #c5d8e8 !important;
    }

    .dx-row-alt td {
        background-color: rgba(255,255,255,0.02) !important;
    }

    .dx-pager {
        background-color: #16213e !important;
        color: #6b8fa8 !important;
        border-top: 1px solid rgba(255,255,255,0.06) !important;
    }

    .dx-page.dx-selection {
        background: #00d2d2 !important;
        color: #0a0f1d !important;
        border-radius: 6px;
    }
</style>

<div class="page-wrapper">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <h2 class="fw-bold mb-0" style="color:#e8f4f8;">👥 Pending User Registrations</h2>
        <div class="text-muted small">Only users waiting for approval are shown here.</div>
    </div>

    <div class="stats-row">
        <div class="stat-box pending">
            <div class="stat-number" id="countPending">—</div>
            <div class="stat-label">⏳ Waiting</div>
        </div>
        <div class="stat-box approved">
            <div class="stat-number" id="countApproved">—</div>
            <div class="stat-label">✅ Approved</div>
        </div>
        <div class="stat-box rejected">
            <div class="stat-number" id="countRejected">—</div>
            <div class="stat-label">❌ Rejected</div>
        </div>
    </div>

    <div id="userGrid"></div>

</div>

<!-- Skills modal (View button opens this) -->
<div class="modal fade" id="skillsModal" tabindex="-1" aria-labelledby="skillsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="background:#0a0f1d;border:1px solid rgba(255,255,255,0.12);">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <h5 class="modal-title" id="skillsModalLabel" style="color:#e8f4f8;">Skills Portfolio</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="skillsModalBody" style="color:#c5d8e8;"></div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/pendingusers.js"></script>
}
