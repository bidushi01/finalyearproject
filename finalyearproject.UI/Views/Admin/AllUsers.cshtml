@{
    ViewData["Title"] = "All Users - Admin";
    Layout = "_Layout";
}
<style>
    .admin-page-wrap { padding: 30px; max-width: 1400px; margin: 0 auto; }
</style>
<div class="admin-page-wrap">
    <h2 class="mb-2" style="color:#e8f4f8;">All Users</h2>
    <p class="text-muted mb-4">Every registered user — with or without skills. Click a row or View to open the skills portfolio (same style as recent changes).</p>
    <div id="allUsersGrid"></div>
</div>
<div class="modal fade" id="skillsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="background:#0a0f1d;border:1px solid rgba(255,255,255,0.12);">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <h5 class="modal-title" id="skillsModalLabel" style="color:#e8f4f8;">Skills portfolio</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="skillsModalBody" style="color:#c5d8e8;"></div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/adminIndex.js" asp-append-version="true"></script>
    <script src="~/js/allUsers.js" asp-append-version="true"></script>
}
